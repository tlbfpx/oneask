# ===========================================
# OneAsk Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env file to git!

# -------------------
# AI Configuration
# -------------------
# DashScope API Key (required for LLM)
# Get your key from: https://dashscope.console.aliyun.com/apiKey
AI_DASHSCOPE_API_KEY=your-dashscope-api-key-here

# -------------------
# Baidu Map Configuration
# -------------------
# Baidu Map AK (required for geocoding)
# Get your key from: https://lbsyun.baidu.com/apiconsole/key
BAIDU_MAP_AK=your-baidu-map-ak-here

# -------------------
# Database Configuration
# -------------------
# MySQL root password for Nacos
MYSQL_ROOT_PASSWORD=nacos123

# -------------------
# Nacos Configuration
# -------------------
# Nacos server address (for service discovery)
NACOS_ADDR=127.0.0.1:8848

# Nacos authentication
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos

# Nacos auth token (for production, generate a secure random string)
NACOS_AUTH_TOKEN=SecretKey012345678901234567890123456789012345678901234567890123456789

# -------------------
# Python Configuration
# -------------------
# Python executable path (optional, defaults to python3)
# PYTHON_PATH=python3
